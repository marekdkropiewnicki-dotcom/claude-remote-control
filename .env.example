# GitHub Agent Command Center

# GitHub Personal Access Token (server-side, never exposed to client)
GITHUB_TOKEN=your_github_personal_access_token

# Admin password — used to authenticate the web UI
ADMIN_TOKEN=your_secret_admin_password

# Repository to monitor for pull requests
NEXT_PUBLIC_REPO_OWNER=marekdkropiewnicki-dotcom
NEXT_PUBLIC_REPO_NAME=GentelmeN-CorE

# Optional: Anthropic API key (if using server-side chat route)
# ANTHROPIC_API_KEY=your-api-key-here
